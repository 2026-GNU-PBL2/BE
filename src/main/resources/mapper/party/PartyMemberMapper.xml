<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="pbl2.sub119.backend.party.mapper.PartyMemberMapper">

    <resultMap id="partyMemberResultMap" type="pbl2.sub119.backend.party.entity.PartyMember">
        <id property="id" column="id"/>
        <result property="partyId" column="party_id"/>
        <result property="userId" column="user_id"/>
        <result property="role" column="role"/>
        <result property="status" column="status"/>
        <result property="joinedAt" column="joined_at"/>
        <result property="activatedAt" column="activated_at"/>
        <result property="serviceStartAt" column="service_start_at"/>
        <result property="serviceEndAt" column="service_end_at"/>
        <result property="leaveReservedAt" column="leave_reserved_at"/>
        <result property="leftAt" column="left_at"/>
        <result property="replacedTargetMemberId" column="replaced_target_member_id"/>
    </resultMap>

    <insert id="insertPartyMember" parameterType="pbl2.sub119.backend.party.entity.PartyMember" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO party_member (
            party_id,
            user_id,
            role,
            status,
            joined_at,
            activated_at,
            service_start_at,
            service_end_at,
            leave_reserved_at,
            left_at,
            replaced_target_member_id
        ) VALUES (
                     #{partyId},
                     #{userId},
                     #{role},
                     #{status},
                     #{joinedAt},
                     #{activatedAt},
                     #{serviceStartAt},
                     #{serviceEndAt},
                     #{leaveReservedAt},
                     #{leftAt},
                     #{replacedTargetMemberId}
                 )
    </insert>

    <select id="findByPartyIdAndUserId" resultMap="partyMemberResultMap">
        SELECT
            id,
            party_id,
            user_id,
            role,
            status,
            joined_at,
            activated_at,
            service_start_at,
            service_end_at,
            leave_reserved_at,
            left_at,
            replaced_target_member_id
        FROM party_member
        WHERE party_id = #{partyId}
          AND user_id = #{userId}
            LIMIT 1
    </select>

    <select id="findMembersByPartyId" resultMap="partyMemberResultMap">
        SELECT
            id,
            party_id,
            user_id,
            role,
            status,
            joined_at,
            activated_at,
            service_start_at,
            service_end_at,
            leave_reserved_at,
            left_at,
            replaced_target_member_id
        FROM party_member
        WHERE party_id = #{partyId}
        ORDER BY id ASC
    </select>

    <select id="countOccupiedMembers" resultType="int">
        SELECT COUNT(*)
        FROM party_member
        WHERE party_id = #{partyId}
          AND status IN ('PENDING', 'ACTIVE')
    </select>

</mapper>