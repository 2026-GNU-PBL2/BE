<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="pbl2.sub119.backend.concurrent.mapper.PartyMemberDeviceMapper">

    <resultMap id="partyMemberDeviceResultMap" type="pbl2.sub119.backend.concurrent.entity.PartyMemberDevice">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="partyId" column="party_id"/>
        <result property="deviceType" column="device_type"/>
        <result property="os" column="os"/>
        <result property="browser" column="browser"/>
        <result property="ipLocation" column="ip_location"/>
        <result property="vpn" column="is_vpn"/>
        <result property="registrationMethod" column="registration_method"/>
        <result property="registeredAt" column="registered_at"/>
    </resultMap>

    <insert id="insert" parameterType="pbl2.sub119.backend.concurrent.entity.PartyMemberDevice"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO party_member_device (
            user_id, party_id, device_type, os, browser, ip_location,
            is_vpn, registration_method, registered_at
        ) VALUES (
            #{userId}, #{partyId}, #{deviceType}, #{os}, #{browser}, #{ipLocation},
            #{vpn}, #{registrationMethod}, NOW()
        )
    </insert>

    <select id="findByUserId" resultMap="partyMemberDeviceResultMap">
        SELECT * FROM party_member_device WHERE user_id = #{userId} ORDER BY registered_at DESC
    </select>

    <select id="findByPartyId" resultMap="partyMemberDeviceResultMap">
        SELECT * FROM party_member_device WHERE party_id = #{partyId} ORDER BY registered_at DESC
    </select>

    <select id="findByUserIdAndPartyId" resultMap="partyMemberDeviceResultMap">
        SELECT * FROM party_member_device
        WHERE user_id = #{userId} AND party_id = #{partyId}
        ORDER BY registered_at DESC
        LIMIT 1
    </select>

    <resultMap id="partyMemberDeviceWithUserResultMap"
               type="pbl2.sub119.backend.concurrent.dto.response.PartyMemberDeviceResponse">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="nickname" column="nickname"/>
        <result property="email" column="submate_email"/>
        <result property="deviceType" column="device_type"/>
        <result property="os" column="os"/>
        <result property="browser" column="browser"/>
        <result property="ipLocation" column="ip_location"/>
        <result property="vpn" column="is_vpn"/>
        <result property="registrationMethod" column="registration_method"/>
        <result property="registeredAt" column="registered_at"/>
    </resultMap>

    <select id="findByPartyIdWithUserInfo" resultMap="partyMemberDeviceWithUserResultMap">
        SELECT pmd.id, pmd.user_id, pmd.device_type, pmd.os, pmd.browser,
               pmd.ip_location, pmd.is_vpn, pmd.registration_method, pmd.registered_at,
               u.nickname, u.submate_email
        FROM party_member_device pmd
                 LEFT JOIN users u ON pmd.user_id = u.id
        WHERE pmd.party_id = #{partyId}
        ORDER BY pmd.registered_at DESC
    </select>

</mapper>
