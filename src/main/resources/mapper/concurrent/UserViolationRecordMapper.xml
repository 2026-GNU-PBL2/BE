<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="pbl2.sub119.backend.concurrent.mapper.UserViolationRecordMapper">

    <resultMap id="violationRecordResultMap" type="pbl2.sub119.backend.concurrent.entity.UserViolationRecord">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="partyId" column="party_id"/>
        <result property="incidentId" column="incident_id"/>
        <result property="violationType" column="violation_type"/>
        <result property="weight" column="weight"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <insert id="insert" parameterType="pbl2.sub119.backend.concurrent.entity.UserViolationRecord"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user_violation_record (user_id, party_id, incident_id, violation_type, weight, created_at)
        VALUES (#{userId}, #{partyId}, #{incidentId}, #{violationType}, #{weight}, NOW())
    </insert>

    <select id="findByUserId" resultMap="violationRecordResultMap">
        SELECT * FROM user_violation_record WHERE user_id = #{userId} ORDER BY created_at DESC
    </select>

    <select id="findByPartyId" resultMap="violationRecordResultMap">
        SELECT * FROM user_violation_record WHERE party_id = #{partyId} ORDER BY created_at DESC
    </select>

</mapper>
