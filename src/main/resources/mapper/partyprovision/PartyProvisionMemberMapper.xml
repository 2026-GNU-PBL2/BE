<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="pbl2.sub119.backend.party.provision.mapper.PartyProvisionMemberMapper">

    <resultMap id="partyOperationMemberResultMap"
               type="pbl2.sub119.backend.party.provision.entity.PartyProvisionMember">
        <id property="id" column="id"/>
        <result property="partyOperationId" column="party_operation_id"/>
        <result property="partyMemberId" column="party_member_id"/>
        <result property="partyId" column="party_id"/>
        <result property="userId" column="user_id"/>
        <result property="memberStatus" column="member_status"
                javaType="pbl2.sub119.backend.party.provision.enumerated.ProvisionMemberStatus"/>
        <result property="inviteSentAt" column="invite_sent_at"/>
        <result property="mustCompleteBy" column="must_complete_by"/>
        <result property="confirmedAt" column="confirmed_at"/>
        <result property="completedAt" column="completed_at"/>
        <result property="activatedAt" column="activated_at"/>
        <result property="lastResetAt" column="last_reset_at"/>
        <result property="penaltyApplied" column="penalty_applied"/>
        <result property="operationMessage" column="operation_message"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <resultMap id="partyOperationMemberResponseResultMap"
               type="pbl2.sub119.backend.party.provision.dto.response.PartyProvisionMemberResponse">
        <constructor>
            <idArg column="id" javaType="java.lang.Long"/>
            <arg column="party_member_id" javaType="java.lang.Long"/>
            <arg column="user_id" javaType="java.lang.Long"/>
            <arg column="nickname" javaType="java.lang.String"/>
            <arg column="member_status"
                 javaType="pbl2.sub119.backend.party.provision.enumerated.ProvisionMemberStatus"/>
            <arg column="invite_sent_at" javaType="java.time.LocalDateTime"/>
            <arg column="must_complete_by" javaType="java.time.LocalDateTime"/>
            <arg column="confirmed_at" javaType="java.time.LocalDateTime"/>
            <arg column="completed_at" javaType="java.time.LocalDateTime"/>
            <arg column="activated_at" javaType="java.time.LocalDateTime"/>
            <arg column="last_reset_at" javaType="java.time.LocalDateTime"/>
            <arg column="penalty_applied" javaType="Boolean"/>
            <arg column="operation_message" javaType="java.lang.String"/>
        </constructor>
    </resultMap>

    <sql id="partyOperationMemberColumns">
        id,
        party_operation_id,
        party_member_id,
        party_id,
        user_id,
        member_status,
        invite_sent_at,
        must_complete_by,
        confirmed_at,
        completed_at,
        activated_at,
        last_reset_at,
        penalty_applied,
        operation_message,
        created_at,
        updated_at
    </sql>

    <!-- provision 멤버 저장 -->
    <insert id="insert"
            parameterType="pbl2.sub119.backend.party.provision.entity.PartyProvisionMember"
            useGeneratedKeys="true"
            keyProperty="id">
        INSERT INTO party_operation_member
        (
            party_operation_id,
            party_member_id,
            party_id,
            user_id,
            member_status,
            invite_sent_at,
            must_complete_by,
            confirmed_at,
            completed_at,
            activated_at,
            last_reset_at,
            penalty_applied,
            operation_message,
            created_at,
            updated_at
        )
        VALUES
            (
                #{partyOperationId},
                #{partyMemberId},
                #{partyId},
                #{userId},
                #{memberStatus},
                #{inviteSentAt},
                #{mustCompleteBy},
                #{confirmedAt},
                #{completedAt},
                #{activatedAt},
                #{lastResetAt},
                #{penaltyApplied},
                #{operationMessage},
                #{createdAt},
                #{updatedAt}
            )
    </insert>

    <!-- 기존 provision 멤버 전체 삭제 -->
    <delete id="deleteByPartyOperationId">
        DELETE FROM party_operation_member
        WHERE party_operation_id = #{partyOperationId}
    </delete>

    <!-- provision 멤버 단건 조회 -->
    <select id="findById" resultMap="partyOperationMemberResultMap">
        SELECT
        <include refid="partyOperationMemberColumns"/>
        FROM party_operation_member
        WHERE id = #{id}
        LIMIT 1
    </select>

    <!-- 파티/유저 기준 provision 멤버 조회 -->
    <select id="findByPartyIdAndUserId" resultMap="partyOperationMemberResultMap">
        SELECT
        <include refid="partyOperationMemberColumns"/>
        FROM party_operation_member
        WHERE party_id = #{partyId}
        AND user_id = #{userId}
        LIMIT 1
    </select>

    <!-- provision 멤버 구성 전체 조회 -->
    <select id="findByPartyOperationId" resultMap="partyOperationMemberResultMap">
        SELECT
        <include refid="partyOperationMemberColumns"/>
        FROM party_operation_member
        WHERE party_operation_id = #{partyOperationId}
        ORDER BY id ASC
    </select>

    <!-- provision 멤버 상태 목록 조회 -->
    <select id="findResponsesByPartyOperationId" resultMap="partyOperationMemberResponseResultMap">
        SELECT
            pom.id,
            pom.party_member_id,
            pom.user_id,
            u.nickname,
            pom.member_status,
            pom.invite_sent_at,
            pom.must_complete_by,
            pom.confirmed_at,
            pom.completed_at,
            pom.activated_at,
            pom.last_reset_at,
            pom.penalty_applied,
            pom.operation_message
        FROM party_operation_member pom
                 INNER JOIN users u ON u.id = pom.user_id
        WHERE pom.party_operation_id = #{partyOperationId}
        ORDER BY pom.id ASC
    </select>

    <!-- 전체 provision 멤버 수 조회 -->
    <select id="countByPartyOperationId" resultType="int">
        SELECT COUNT(*)
        FROM party_operation_member
        WHERE party_operation_id = #{partyOperationId}
    </select>

    <!-- ACTIVE provision 멤버 수 조회 -->
    <select id="countActiveByPartyOperationId" resultType="int">
        SELECT COUNT(*)
        FROM party_operation_member
        WHERE party_operation_id = #{partyOperationId}
          AND member_status = 'ACTIVE'
    </select>

    <!-- 파티/유저 provision 멤버 존재 여부 조회 -->
    <select id="countByPartyIdAndUserId" resultType="int">
        SELECT COUNT(*)
        FROM party_operation_member
        WHERE party_id = #{partyId}
          AND user_id = #{userId}
    </select>

    <!-- provision 완료 확인 처리 -->
    <update id="markActive">
        UPDATE party_operation_member
        SET
            member_status = #{memberStatus},
            confirmed_at = #{confirmedAt},
            completed_at = #{completedAt},
            activated_at = #{activatedAt},
            updated_at = #{updatedAt}
        WHERE id = #{id}
    </update>

    <!-- provision 재설정 필요 상태로 일괄 변경 -->
    <update id="markAllResetRequired">
        UPDATE party_operation_member
        SET
            member_status = #{memberStatus},
            operation_message = #{operationMessage},
            last_reset_at = #{lastResetAt},
            confirmed_at = NULL,
            completed_at = NULL,
            activated_at = NULL,
            updated_at = #{updatedAt}
        WHERE party_operation_id = #{partyOperationId}
    </update>

</mapper>