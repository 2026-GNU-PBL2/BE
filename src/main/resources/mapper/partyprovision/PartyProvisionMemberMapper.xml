<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="pbl2.sub119.backend.party.provision.mapper.PartyProvisionMemberMapper">

    <resultMap id="partyOperationMemberResponseResultMap"
               type="pbl2.sub119.backend.party.provision.dto.response.PartyProvisionMemberResponse">
        <constructor>
            <idArg column="id" javaType="java.lang.Long"/>
            <arg column="party_member_id" javaType="java.lang.Long"/>
            <arg column="user_id" javaType="java.lang.Long"/>
            <arg column="nickname" javaType="java.lang.String"/>
            <arg column="member_status"
                 javaType="pbl2.sub119.backend.party.provision.enumerated.ProvisionMemberStatus"/>
            <arg column="invite_sent_at" javaType="java.time.LocalDateTime"/>
            <arg column="must_complete_by" javaType="java.time.LocalDateTime"/>
            <arg column="confirmed_at" javaType="java.time.LocalDateTime"/>
            <arg column="completed_at" javaType="java.time.LocalDateTime"/>
            <arg column="activated_at" javaType="java.time.LocalDateTime"/>
            <arg column="last_reset_at" javaType="java.time.LocalDateTime"/>
            <arg column="penalty_applied" javaType="Boolean"/>
            <arg column="operation_message" javaType="java.lang.String"/>
        </constructor>
    </resultMap>

    <resultMap id="partyOperationMemberResponseResultMap"
               type="pbl2.sub119.backend.party.provision.dto.response.PartyProvisionMemberResponse">
        <constructor>
            <idArg column="id" javaType="java.lang.Long"/>
            <arg column="party_member_id" javaType="java.lang.Long"/>
            <arg column="user_id" javaType="java.lang.Long"/>
            <arg column="member_status"
                 javaType="pbl2.sub119.backend.party.provision.enumerated.ProvisionMemberStatus"/>
            <arg column="invite_sent_at" javaType="java.time.LocalDateTime"/>
            <arg column="must_complete_by" javaType="java.time.LocalDateTime"/>
            <arg column="confirmed_at" javaType="java.time.LocalDateTime"/>
            <arg column="completed_at" javaType="java.time.LocalDateTime"/>
            <arg column="activated_at" javaType="java.time.LocalDateTime"/>
            <arg column="last_reset_at" javaType="java.time.LocalDateTime"/>
            <arg column="penalty_applied" javaType="Boolean"/>
            <arg column="operation_message" javaType="java.lang.String"/>
        </constructor>
    </resultMap>

    <sql id="partyOperationMemberColumns">
        id,
        party_operation_id,
        party_member_id,
        party_id,
        user_id,
        member_status,
        invite_sent_at,
        must_complete_by,
        confirmed_at,
        completed_at,
        activated_at,
        last_reset_at,
        penalty_applied,
        operation_message,
        created_at,
        updated_at
    </sql>

    <!--결제 완료 후 파티 운영 시작 시 현재 ACTIVE 파티원들을 운영 멤버로 초기 셋팅-->
    <insert id="insert"
            parameterType="pbl2.sub119.backend.party.provision.entity.PartyProvisionMember"
            useGeneratedKeys="true"
            keyProperty="id">
        INSERT INTO party_operation_member
        (
            party_operation_id,
            party_member_id,
            party_id,
            user_id,
            member_status,
            invite_sent_at,
            must_complete_by,
            confirmed_at,
            completed_at,
            activated_at,
            last_reset_at,
            penalty_applied,
            operation_message,
            created_at,
            updated_at
        )
        VALUES
            (
                #{partyOperationId},
                #{partyMemberId},
                #{partyId},
                #{userId},
                #{memberStatus},
                #{inviteSentAt},
                #{mustCompleteBy},
                #{confirmedAt},
                #{completedAt},
                #{activatedAt},
                #{lastResetAt},
                #{penaltyApplied},
                #{operationMessage},
                #{createdAt},
                #{updatedAt}
            )
    </insert>

    <!--기존 운영 멤버 전체 삭제 후 재생성-->
    <delete id="deleteByPartyOperationId">
        DELETE FROM party_operation_member
        WHERE party_operation_id = #{partyOperationId}
    </delete>

    <!--특정 멤버 상태 변경할 때 운영 멤버 단건 조회-->
    <select id="findById" resultMap="partyOperationMemberResultMap">
        SELECT
        <include refid="partyOperationMemberColumns"/>
        FROM party_operation_member
        WHERE id = #{id}
        LIMIT 1
    </select>

    <!--파티원이 본인 상태 확인할 때 운영 상태 단건 조회-->
    <select id="findByPartyIdAndUserId" resultMap="partyOperationMemberResultMap">
        SELECT
        <include refid="partyOperationMemberColumns"/>
        FROM party_operation_member
        WHERE party_id = #{partyId}
        AND user_id = #{userId}
        LIMIT 1
    </select>

    <!--cycle start 이후 현재 운영 멤버 구성 비교용 조회-->
    <select id="findByPartyOperationId" resultMap="partyOperationMemberResultMap">
        SELECT
        <include refid="partyOperationMemberColumns"/>
        FROM party_operation_member
        WHERE party_operation_id = #{partyOperationId}
        ORDER BY id ASC
    </select>

    <!--파티장/파티원이 운영 현황 확인할 때 전체 멤버 상태 리스트 반환-->
    <select id="findResponsesByPartyOperationId" resultMap="partyOperationMemberResponseResultMap">
        SELECT
            pom.id,
            pom.party_member_id,
            pom.user_id,
            u.nickname,
            pom.member_status,
            pom.invite_sent_at,
            pom.must_complete_by,
            pom.confirmed_at,
            pom.completed_at,
            pom.activated_at,
            pom.last_reset_at,
            pom.penalty_applied,
            pom.operation_message
        FROM party_operation_member pom
                 INNER JOIN users u ON u.id = pom.user_id
        WHERE pom.party_operation_id = #{partyOperationId}
        ORDER BY pom.id ASC
    </select>

    <!--운영 진행률 계산할 때 전체 멤버 수 집계-->
    <select id="countByPartyOperationId" resultType="int">
        SELECT COUNT(*)
        FROM party_operation_member
        WHERE party_operation_id = #{partyOperationId}
    </select>

    <!--전원 완료 여부 판단할 때 이용 가능 멤버 수 집계-->
    <select id="countActiveByPartyOperationId" resultType="int">
        SELECT COUNT(*)
        FROM party_operation_member
        WHERE party_operation_id = #{partyOperationId}
          AND member_status = 'ACTIVE'
    </select>

    <select id="countByPartyIdAndUserId" resultType="int">
        SELECT COUNT(*)
        FROM party_operation_member
        WHERE party_id = #{partyId}
          AND user_id = #{userId}
    </select>

    <!--파티원이 초대 수락 및 계정 설정 완료 시 ACTIVE로 상태 전환 + 이용 가능 처리-->
    <update id="markActive">
        UPDATE party_operation_member
        SET
            member_status = #{memberStatus},
            confirmed_at = #{confirmedAt},
            completed_at = #{completedAt},
            activated_at = #{activatedAt},
            updated_at = #{updatedAt}
        WHERE id = #{id}
    </update>

    <!--결제 주기 변경 및 멤버 변경 발생 시 모든 멤버 상태 초기화 및 재설정 필요 상태로 변경-->
    <update id="markAllResetRequired">
        UPDATE party_operation_member
        SET
            member_status = #{memberStatus},
            operation_message = #{operationMessage},
            last_reset_at = #{lastResetAt},
            confirmed_at = NULL,
            completed_at = NULL,
            activated_at = NULL,
            updated_at = #{updatedAt}
        WHERE party_operation_id = #{partyOperationId}
    </update>

</mapper>