<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="pbl2.sub119.backend.party.provision.mapper.PartyProvisionMapper">

    <resultMap id="partyOperationResultMap"
               type="pbl2.sub119.backend.party.provision.entity.PartyProvision">
        <id property="id" column="id"/>
        <result property="partyId" column="party_id"/>
        <result property="operationType" column="operation_type"
                javaType="pbl2.sub119.backend.party.provision.enumerated.ProvisionType"/>
        <result property="operationStatus" column="operation_status"
                javaType="pbl2.sub119.backend.party.provision.enumerated.ProvisionStatus"/>
        <result property="inviteValue" column="invite_value"/>
        <result property="sharedAccountEmail" column="shared_account_email"/>
        <result property="sharedAccountPasswordEncrypted" column="shared_account_password_encrypted"/>
        <result property="operationGuide" column="operation_guide"/>
        <result property="operationStartedAt" column="operation_started_at"/>
        <result property="operationCompletedAt" column="operation_completed_at"/>
        <result property="lastResetAt" column="last_reset_at"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="partyOperationColumns">
        id,
        party_id,
        operation_type,
        operation_status,
        invite_value,
        shared_account_email,
        shared_account_password_encrypted,
        operation_guide,
        operation_started_at,
        operation_completed_at,
        last_reset_at,
        created_at,
        updated_at
    </sql>

    <!-- 48시간 초과 → 파티 해체 -->
    <select id="findTimedOutProvisions" resultMap="partyOperationResultMap">
        SELECT
        <include refid="partyOperationColumns"/>
        FROM party_operation
        WHERE operation_status != 'ACTIVE'
        AND operation_started_at IS NULL
        AND TIMESTAMPDIFF(HOUR, created_at, NOW()) >= 48
    </select>

    <!-- 12시간 / 22시간 → 파티장 리마인드 -->
    <select id="findHostProvisionReminderDue" resultMap="partyOperationResultMap">
        SELECT
        <include refid="partyOperationColumns"/>
        FROM party_operation
        WHERE operation_status != 'ACTIVE'
        AND operation_started_at IS NULL
        AND TIMESTAMPDIFF(HOUR, created_at, NOW()) >= #{elapsedHours}
        AND TIMESTAMPDIFF(HOUR, created_at, NOW()) <![CDATA[<]]> #{elapsedHours} + 1
    </select>

    <!-- 24시간 → 파티원에게 지연 안내 -->
    <select id="findHostProvisionDelayedNoticeDue" resultMap="partyOperationResultMap">
        SELECT
        <include refid="partyOperationColumns"/>
        FROM party_operation
        WHERE operation_status != 'ACTIVE'
        AND operation_started_at IS NULL
        AND TIMESTAMPDIFF(HOUR, created_at, NOW()) >= #{elapsedHours}
        AND TIMESTAMPDIFF(HOUR, created_at, NOW()) <![CDATA[<]]> #{elapsedHours} + 1
    </select>

</mapper>